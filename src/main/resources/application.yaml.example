server:
  port: 8081

spring:
  datasource:
    url: jdbc:mysql://${DB_HOST:localhost}:3306/saas-map?characterEncoding=utf8&allowMultiQueries=true
    username: ${DB_USERNAME:root}
    password: ${DB_PASSWORD:your_password}
    driver-class-name: com.mysql.cj.jdbc.Driver
    hikari:
      connection-timeout: 30000
      maximum-pool-size: 10
      minimum-idle: 5
      idle-timeout: 600000
      max-lifetime: 1800000
  # 文件上传配置
  servlet:
    multipart:
      enabled: true
      max-file-size: 200MB
      max-request-size: 200MB

mybatis-plus:
  configuration:
    map-underscore-to-camel-case: true
    log-impl: org.apache.ibatis.logging.stdout.StdOutImpl

# 阿里云 OSS 配置
aliyun:
  oss:
    access-key-id: ${ALIBABA_ACCESS_KEY:YOUR_ALIYUN_ACCESS_KEY_ID}
    access-key-secret: ${ALIBABA_SECRET_KEY:YOUR_ALIYUN_ACCESS_KEY_SECRET}
    endpoint: oss-cn-hangzhou.aliyuncs.com
    bucket-name: your-video-bucket
    image-bucket-name: your-image-bucket
    base-prefix: videos/attractionVideo/video/xhQ1/
    video-cdn-domain: https://videos.yourdomain.com
    image-cdn-domain: https://images.yourdomain.com

# 视频转码配置
transcode:
  enabled: true
  temp-dir: /tmp/video_transcode   # Windows环境请修改为：D:/temp/video_transcode
